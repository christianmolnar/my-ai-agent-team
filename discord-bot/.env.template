# Discord Bot Environment Configuration - SECURITY FOCUSED
# 
# 🔐 IMPORTANT: This file will be renamed to .env.local during setup
# 🔐 .env.local is NEVER committed to git for maximum security
# 🔐 Your tokens will remain private and never accidentally shared
#
# Copy this to .env.local and fill in your actual tokens

# Discord Bot Token - Get from https://discord.com/developers/applications
# Go to your app → Bot → Token (NOT the public key!)
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Anthropic API Key - Get from https://console.anthropic.com/settings/keys  
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: Custom CNS Directory (defaults to E:\Repos\my-ai-agent-team\.personal-cns\cns)
# CNS_DIR=C:\your\custom\path\to\cns

# Optional: Log Level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO